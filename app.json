{
  "expo": {
    "name": "native-pronunciation-app",
    "slug": "native-pronunciation-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ryuhosoy.nativepronunciationapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "06f2e2a8-955c-4484-aa42-9375028309fc"
      }
    },
    "build": {
      "development": {
        "ios": {
          "simulator": true
        }
      }
    },
    "owner": "ryuhosoy"
  }
}
